<svg width="120" height="120" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad" x1="0" y1="0" x2="120" y2="120">
      <stop offset="0%" stop-color="#6366f1"></stop>
      <stop offset="100%" stop-color="#22c55e"></stop>
